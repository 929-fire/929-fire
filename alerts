<!DOCTYPE html>
<html lang="tl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>929 Dispatch Incident Reporter</title>
    <style>
        :root {
            --primary-color: #ff4d4d;
            --primary-dark: #cc0000;
            --bg-color: #121212;
            --card-bg: #1e1e1e;
            --text-color: #ffffff;
            --text-muted: #b0b0b0;
            --border-color: #333333;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            padding: 20px;
        }

        .container {
            max-width: 600px;
            margin: 30px auto;
            background: var(--card-bg);
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.5);
            border: 1px solid var(--border-color);
        }

        .header {
            text-align: center;
            margin-bottom: 25px;
            border-bottom: 2px solid var(--primary-color);
            padding-bottom: 15px;
        }

        .header h1 {
            font-size: 24px;
            color: var(--primary-color);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .header p {
            font-size: 14px;
            color: var(--text-muted);
            margin-top: 5px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 14px;
            color: var(--text-muted);
        }

        input[type="text"], select, textarea {
            width: 100%;
            padding: 12px;
            background-color: #2a2a2a;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            color: white;
            font-size: 15px;
        }

        input[type="text"]:focus, select:focus, textarea:focus {
            border-color: var(--primary-color);
            outline: none;
        }

        .row {
            display: flex;
            gap: 15px;
        }

        .col {
            flex: 1;
        }

        .btn-submit {
            background-color: var(--primary-color);
            color: white;
            border: none;
            padding: 14px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 6px;
            cursor: pointer;
            width: 100%;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: background-color 0.2s ease;
        }

        .btn-submit:hover {
            background-color: var(--primary-dark);
        }

        .btn-submit:disabled {
            background-color: #555;
            cursor: not-allowed;
        }

        .status-box {
            margin-top: 20px;
            padding: 12px;
            border-radius: 6px;
            font-size: 14px;
            text-align: center;
            display: none;
        }

        .status-loading { background-color: #332700; color: #ffcc00; border: 1px solid #664d00; display: block; }
        .status-success { background-color: #143317; color: #4caf50; border: 1px solid #1e4d22; display: block; }
        .status-error { background-color: #331414; color: #f44336; border: 1px solid #4d1e1e; display: block; }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h1>929 Dispatch Input System</h1>
        <p>Awtomatikong pag-add ng alert sa repository database</p>
    </div>

    <div style="background: #151515; padding: 10px; border-radius: 6px; margin-bottom: 20px; font-size: 12px; color: var(--text-muted); border-left: 3px solid var(--primary-color);">
        <strong>Target Destination:</strong> <span style="color: #fff;">929-fire / </span>
        <input type="text" id="repoName" value="929-alerts" style="width: 100px; padding: 2px; background: #000; border: 1px solid #333; color: #fff; font-size: 11px;"> / 
        <input type="text" id="filePath" value="alerts.json" style="width: 90px; padding: 2px; background: #000; border: 1px solid #333; color: #fff; font-size: 11px;">
        <br><small style="color: #666;">*Maaari mong baguhin ang nakasulat na Repo o File path kung mag-iiba ang iyong repository.</small>
    </div>

    <form id="incidentForm">
        <div class="form-group">
            <label for="reporterName">Dispatcher / Reporter Name:</label>
            <input type="text" id="reporterName" required placeholder="E.g., Drin Wx / Dispatcher 01">
        </div>

        <div class="row">
            <div class="col">
                <div class="form-group">
                    <label for="alertCode">Alert Code (10-Code):</label>
                    <select id="alertCode" required>
                        <option value="10-70">10-70 (Fire Alert / Sunog)</option>
                        <option value="10-50">10-50 (Vehicle Accident)</option>
                        <option value="10-16">10-16 (Medical Emergency)</option>
                        <option value="10-74">10-74 (Rescue / Others)</option>
                    </select>
                </div>
            </div>
            <div class="col">
                <div class="form-group">
                    <label for="alertType">Uri ng Insidente (Text):</label>
                    <input type="text" id="alertType" value="Fire Alert" readonly style="background-color: #1a1a1a; color: #888;">
                </div>
            </div>
        </div>

        <div class="form-group">
            <label for="location">Eksaktong Lokasyon / Address:</label>
            <input type="text" id="location" required placeholder="E.g., Sala Nia Road along Tarikan, Cabuyao, Laguna">
        </div>

        <div class="form-group">
            <label for="involved">Mga Sangkot (Involved):</label>
            <input type="text" id="involved" required value="N/A" placeholder="E.g., 2 motor vehicles, Residential building">
        </div>

        <div class="row">
            <div class="col">
                <div class="form-group">
                    <label for="status">Kasalukuyang Status:</label>
                    <select id="status" required>
                        <option value="For Verification">For Verification</option>
                        <option value="Positive">Positive</option>
                        <option value="Responding">Responding / En Route</option>
                        <option value="Under Control">Under Control</option>
                        <option value="Clear">Clear / Code 10-42</option>
                    </select>
                </div>
            </div>
            <div class="col">
                <div class="form-group">
                    <label for="dateTime">Petsa at Oras (Awtomatiko):</label>
                    <input type="text" id="dateTime" readonly style="background-color: #1a1a1a; color: #888;">
                </div>
            </div>
        </div>

        <div class="form-group">
            <label for="notes">Mga Karagdagang Tala (Notes):</label>
            <textarea id="notes" rows="3" placeholder="E.g., On Going 911, Bureau of Fire Responding, o N/A">N/A</textarea>
        </div>

        <div id="statusBox" class="status-box"></div>

        <button type="submit" class="btn-submit" id="submitBtn">I-send Alert sa System</button>
    </form>
</div>

<script>
    // Ang bago mong GitHub Token na 100% active at may repo permissions
    const GITHUB_TOKEN = "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"; 
    
    // Naka-hardcode na ang iyong 929-fire organization structure
    const REPO_OWNER = "929-fire";

    const codeMap = {
        "10-70": "Fire Alert",
        "10-50": "Vehicle Accident",
        "10-16": "Medical Emergency",
        "10-74": "Rescue / Emergency"
    };

    document.getElementById('alertCode').addEventListener('change', function() {
        document.getElementById('alertType').value = codeMap[this.value] || "Emergency Alert";
    });

    // Philippine Standard Time Clock Parser
    function updateTimestamp() {
        const now = new Date();
        const year = now.getFullYear();
        const month = String(now.getMonth() + 1).padStart(2, '0');
        const day = String(now.getDate()).padStart(2, '0');
        
        let hours = now.getHours();
        const minutes = String(now.getMinutes()).padStart(2, '0');
        const seconds = String(now.getSeconds()).padStart(2, '0');
        const ampm = hours >= 12 ? 'PM' : 'AM';
        
        hours = hours % 12;
        hours = hours ? hours : 12; 
        const strTime = String(hours).padStart(2, '0') + ':' + minutes + ':' + seconds + ampm;
        
        document.getElementById('dateTime').value = `${year}-${month}-${day}T${strTime}`;
    }
    
    setInterval(updateTimestamp, 1000);
    updateTimestamp();

    function showStatus(message, type) {
        const box = document.getElementById('statusBox');
        box.className = "status-box status-" + type;
        box.innerText = message;
        box.style.display = "block";
    }

    // Submission Handler Engine via GitHub REST API
    document.getElementById('incidentForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const submitBtn = document.getElementById('submitBtn');
        const repoName = document.getElementById('repoName').value.trim();
        const filePath = document.getElementById('filePath').value.trim();

        submitBtn.disabled = true;
        showStatus("Kinokonekta ang GitHub at binabasa ang kasalukuyang database file...", "loading");

        // Gumawa ng Unique Alert Dispatch Tracking Code
        const uniqueId = "929-CMD-" + String(Date.now()).slice(-3);

        const newAlertData = {
            "alert_id": uniqueId,
            "alert_code": document.getElementById('alertCode').value,
            "alert_type": document.getElementById('alertType').value,
            "location": document.getElementById('location').value.trim(),
            "involved": document.getElementById('involved').value.trim(),
            "status": document.getElementById('status').value,
            "date_time": document.getElementById('dateTime').value,
            "notes": document.getElementById('notes').value.trim(),
            "reporter": document.getElementById('reporterName').value.trim()
        };

        const url = `https://api.github.com/repos/${REPO_OWNER}/${repoName}/contents/${filePath}`;

        try {
            let currentSha = null;
            let currentJsonStructure = {
                "metadata": {
                    "system_name": "929 Alerts Dispatch System",
                    "version": "1.12",
                    "source": "929-API/Drin Wx",
                    "timezone": "Asia/Manila",
                    "description": "Real-time alerts monitoring and dispatch system."
                },
                "fire_alerts": []
            };

            // 1. Kunin ang lumang records mula sa iyong repository
            const response = await fetch(url, {
                headers: {
                    "Authorization": `token ${GITHUB_TOKEN}`,
                    "Accept": "application/vnd.github.v3+json",
                    "Cache-Control": "no-cache"
                }
            });

            if (response.status === 200) {
                const fileData = await response.json();
                currentSha = fileData.sha;
                
                const decodedString = decodeURIComponent(escape(atob(fileData.content)));
                currentJsonStructure = JSON.parse(decodedString);
            } else if (response.status === 404) {
                console.log("File not found, automatic initializing standard template structure.");
            } else if (response.status === 401) {
                throw new Error("401 Unauthorized. Invalid o revoked ang bagong token mo. Check permissions.");
            } else {
                throw new Error(`Error sa pagkonekta. Status: ${response.status}`);
            }

            if (!currentJsonStructure.fire_alerts) {
                currentJsonStructure.fire_alerts = [];
            }

            // 2. Unshift - Isalpak ang bagong emergency alert sa unahan para itaas agad sa visual alerts page
            currentJsonStructure.fire_alerts.unshift(newAlertData);

            const updatedJsonString = JSON.stringify(currentJsonStructure, null, 2);
            const base64Content = btoa(unescape(encodeURIComponent(updatedJsonString)));

            // 3. I-commit at i-upload pabalik sa GitHub ang updated file
            const pushPayload = {
                message: `929 Dispatch Alert: Logged ${newAlertData.alert_code} at ${newAlertData.location}`,
                content: base64Content
            };

            if (currentSha) {
                pushPayload.sha = currentSha;
            }

            const putResponse = await fetch(url, {
                method: "PUT",
                headers: {
                    "Authorization": `token ${GITHUB_TOKEN}`,
                    "Content-Type": "application/json",
                    "Accept": "application/vnd.github.v3+json"
                },
                body: JSON.stringify(pushPayload)
            });

            if (putResponse.ok) {
                showStatus(`Tagumpay! Nai-post ang ${newAlertData.alert_code}. Updated na ang iyong database file.`, "success");
                // Reset ang main text areas pagkatapos mag-load
                document.getElementById('location').value = "";
                document.getElementById('involved').value = "N/A";
                document.getElementById('notes').value = "N/A";
            } else {
                const errJson = await putResponse.json();
                throw new Error(errJson.message || "Pumalya ang pag-update sa GitHub content.");
            }

        } catch (error) {
            console.error(error);
            showStatus("Error: " + error.message, "error");
        } finally {
            submitBtn.disabled = false;
        }
    });
</script>

</body>
</html>
